      "name": "Shopper Profile",
      "item": [
        {
          "name": "login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Basic Status & Performance\r",
                  "pm.test(\"Status code is 200\", () => pm.response.to.have.status(200));\r",
                  "pm.test(\"Response time is < 2000ms\", () => pm.expect(pm.response.responseTime).to.be.below(2000));\r",
                  "\r",
                  "// Parse the Response\r",
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "// Logic Validation\r",
                  "pm.test(\"Verify User Role is SHOPPER\", () => {\r",
                  "    pm.expect(jsonData.data.role).to.eql(\"SHOPPER\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Verify Email in response matches the request\", () => {\r",
                  "    const requestBody = JSON.parse(pm.request.body.raw);\r",
                  "    pm.expect(jsonData.data.email).to.eql(requestBody.email);\r",
                  "});\r",
                  "\r",
                  "// Secure/Setting an Environment Variable\r",
                  "pm.environment.set(\"BToken\", jsonData.data.jwtToken);\r",
                  "pm.environment.set(\"shopperId\", jsonData.data.userId);\r",
                  "pm.environment.set(\"zoneId\", jsonData.data.zoneId);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"Your_Email_@gmail.com\",\r\n  \"password\": \"Enter_Your_Password\",\r\n  \"role\": \"SHOPPER\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
